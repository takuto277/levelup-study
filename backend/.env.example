# ============================================================
# LevelUp Study Backend — 環境変数
# ============================================================
# このファイルを .env にコピーして値を埋めてください:
#   cp .env.example .env
#
# .env は .gitignore に含まれるためリポジトリにはコミットされません。
# ============================================================

# --- データベース ---
# ローカル開発 (Docker Compose):
DATABASE_URL=host=localhost user=postgres password=postgres dbname=levelup_study port=5432 sslmode=disable
# Supabase の場合:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# --- golang-migrate（make migrate-up 用）---
# Docker 内からホストの Postgres に接続する URI。ローカルはデフォルトで Makefile が埋める。
# 手元で変える場合の例:
# MIGRATE_DATABASE_URL=postgres://postgres:postgres@host.docker.internal:5432/levelup_study?sslmode=disable

# --- 認証 ---
# Supabase プロジェクトの JWT Secret (Settings > API > JWT Secret)
JWT_SECRET=your-super-secret-jwt-token-change-me

# --- API Key ---
# モバイルアプリ識別用。任意の長いランダム文字列を設定。
# 生成例: openssl rand -hex 32
API_KEY=change-me-to-a-random-string

# --- CORS ---
# カンマ区切りで許可オリジンを列挙（モバイルアプリのみなら空でOK）
ALLOWED_ORIGINS=

# --- サーバー ---
PORT=8080

# --- 開発モード ---
# true にすると JWT / API Key の検証をスキップ（ローカル開発用）
DEV_MODE=true
